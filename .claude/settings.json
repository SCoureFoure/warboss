{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(npm install*)",
      "Bash(npm run*)",
      "Bash(npm test*)",
      "Bash(npx tsc*)",
      "Bash(tsx *)",
      "Bash(node *)",
      "Bash(ls*)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(git status)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(rm -rf *)",
      "Bash(Remove-Item -Recurse*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/src/hooks/record-cost.ts\" --kind claudecode.main",
            "async": true,
            "statusMessage": "Metering main-turn cost"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/src/hooks/record-cost.ts\" --kind claudecode.subagent",
            "async": true,
            "statusMessage": "Metering subagent cost"
          }
        ]
      }
    ]
  }
}
